# .env.example — Variáveis de ambiente do Girassol
# Copie para .env e preencha os valores

# VAPID keys para notificações push
# Gerar com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Upstash Redis
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Autenticação
CRON_SECRET=
VITE_SYNC_API_KEY=
